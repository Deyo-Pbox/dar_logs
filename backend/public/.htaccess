RewriteEngine On

# Pass Authorization header to PHP (CGI/FastCGI strips it)
RewriteCond %{HTTP:Authorization} ^(.+)$
RewriteRule .* - [E=HTTP_AUTHORIZATION:%1]

# ── Cache headers for static assets ──────────────────────────
# Vite builds use content hashes in filenames, so these can be
# cached for a full year without staleness issues.
<IfModule mod_expires.c>
    ExpiresActive On

    # CSS/JS — content-hashed by Vite, immutable
    ExpiresByType text/css                       "access plus 1 year"
    ExpiresByType application/javascript         "access plus 1 year"

    # Images — rarely change
    ExpiresByType image/png                      "access plus 1 year"
    ExpiresByType image/svg+xml                  "access plus 1 year"
    ExpiresByType image/jpeg                     "access plus 1 year"
    ExpiresByType image/webp                     "access plus 1 year"

    # Favicon
    ExpiresByType image/x-icon                   "access plus 1 year"
    ExpiresByType image/vnd.microsoft.icon       "access plus 1 year"
</IfModule>

# Explicit Cache-Control for hashed assets (fallback if mod_expires is unavailable)
<IfModule mod_headers.c>
    <FilesMatch "\.(css|js|png|svg|jpg|jpeg|webp|ico)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    <FilesMatch "index\.html$">
        Header set Cache-Control "no-cache"
    </FilesMatch>
</IfModule>

# ── SPA fallback ────────────────────────────────────────────
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [QSA,L]

<FilesMatch "\.(env|log|sql)$">
    Require all denied
</FilesMatch>
