<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/backgroundImage"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:src="@drawable/login_bg_sunset"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/loginSwipeRefresh"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="0dp">

            <androidx.cardview.widget.CardView
                android:id="@+id/loginCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="32dp"
                android:maxWidth="420dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="32dp"
                app:cardElevation="12dp"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:padding="28dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/logoImage"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginBottom="16dp"
                android:src="@drawable/dar_logo_white_round"
                android:padding="2dp"
                android:background="@android:color/transparent"
                app:shapeAppearanceOverlay="@style/CircleImage"
                android:contentDescription="DAR Logo" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SECURE ACCESS"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:paddingHorizontal="14dp"
                android:paddingVertical="5dp"
                android:background="@drawable/login_new_button_bg"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Welcome Back"
                android:textColor="#0A1F44"
                android:textSize="26sp"
                android:gravity="center"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sign in to your account."
                android:textColor="#5E6C84"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_marginBottom="24dp" />

                    <!-- Profile / Remembered Account Section -->
                    <LinearLayout
                        android:id="@+id/profileSection"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:visibility="gone"
                        android:layout_marginBottom="24dp">

                        <FrameLayout
                            android:id="@+id/profileAvatarContainer"
                            android:layout_width="84dp"
                            android:layout_height="84dp"
                            android:background="@drawable/login_avatar_bg">
                            <TextView
                                android:id="@+id/profileInitial"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:text="H"
                                android:textSize="36sp"
                                android:textStyle="bold"
                                android:textColor="#144326" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/profileDisplayName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:text="hahahah"
                            android:textColor="#0A1F44"
                            android:textSize="22sp"
                            android:textStyle="bold" />

                        <View
                            android:layout_width="32dp"
                            android:layout_height="3dp"
                            android:layout_marginTop="8dp"
                            android:background="#FFC107" />
                    </LinearLayout>

                    <EditText
                        android:id="@+id/usernameInput"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:hint="Username"
                        android:inputType="textPersonName"
                        android:paddingHorizontal="20dp"
                        android:background="@drawable/login_new_input_bg"
                        android:textColor="#0A1F44"
                        android:textColorHint="#A5B1C2"
                        android:layout_marginBottom="16dp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/login_new_input_bg">

                <EditText
                    android:id="@+id/passwordInput"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="48dp"
                    android:hint="Password"
                    android:inputType="textPassword"
                    android:paddingHorizontal="20dp"
                    android:textColor="#0A1F44"
                    android:textColorHint="#A5B1C2"
                    android:background="@android:color/transparent"
                    android:gravity="center_vertical" />

                <ImageButton
                    android:id="@+id/showPasswordToggle"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_gravity="end|center_vertical"
                    android:layout_marginEnd="10dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="10dp"
                    android:src="@drawable/ic_eye"
                    android:contentDescription="@string/show_password"
                    android:tint="#144326" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <Button
                    android:id="@+id/loginButton"
                    android:layout_width="0dp"
                    android:layout_height="58dp"
                    android:layout_weight="1"
                    android:text="Log In"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:background="@drawable/login_new_button_bg"
                    android:foreground="?attr/selectableItemBackground"
                    app:backgroundTint="@null" />

                <ImageButton
                    android:id="@+id/biometricLoginButton"
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:layout_marginStart="14dp"
                    android:background="@drawable/login_avatar_bg"
                    android:src="@drawable/fingerprint"
                    android:padding="14dp"
                    android:scaleType="fitCenter"
                    android:visibility="gone"
                    android:contentDescription="Login with biometric" />
            </LinearLayout>

            <ProgressBar
                android:id="@+id/loginProgress"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                android:indeterminateTint="#144326" />

            <TextView
                android:id="@+id/footer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Authorized users only."
                android:textColor="#7A869A"
                android:textSize="13sp"
                android:gravity="center" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

        </FrameLayout>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
