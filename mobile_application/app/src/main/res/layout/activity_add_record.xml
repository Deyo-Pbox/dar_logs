<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add New Record"
            android:textAppearance="?attr/textAppearanceHeadlineSmall"
            android:textStyle="bold"
            android:paddingBottom="12dp" />

        <Spinner
            android:id="@+id/spinnerMunicipality"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:prompt="@string/prompt_municipality" />

        <EditText
            android:id="@+id/inputClaimant"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Claimant"
            android:inputType="textPersonName"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/inputTitleNo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Title No"
            android:inputType="text"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/inputOdtsNo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="ODTS No"
            android:inputType="text"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/inputLotNo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Lot No"
            android:inputType="text"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/inputSurveyNo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Survey No"
            android:inputType="text"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/inputAreaHas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Area (Has)"
            android:inputType="text"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/inputLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Location"
            android:inputType="text"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/inputTransmittedDocuments"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Transmitted Documents"
            android:inputType="text"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/inputRouteTo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Route To"
            android:inputType="text"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/inputReceivedByControlNo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Received By Control No"
            android:inputType="text"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/inputRemarks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Remarks / Action Taken"
            android:inputType="textMultiLine"
            android:minLines="3"
            android:gravity="top"
            android:layout_marginTop="12dp" />

        <Spinner
            android:id="@+id/spinnerStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:prompt="@string/prompt_status" />

        <Button
            android:id="@+id/buttonSubmit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Submit"
            android:layout_marginTop="20dp" />
    </LinearLayout>
</ScrollView>
